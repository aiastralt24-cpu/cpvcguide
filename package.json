{
  "name": "cpvc-guide",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate-content && next build",
    "start": "next start",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint .",
    "typecheck": "tsc --noEmit",
    "validate-content": "node scripts/validate-content.mjs",
    "content:init": "node scripts/content-pipeline.mjs init",
    "content:autobrief": "node scripts/content-pipeline.mjs autobrief",
    "content:autodraft": "node scripts/content-pipeline.mjs autodraft",
    "content:autoedit": "node scripts/content-pipeline.mjs autoedit",
    "content:final-review": "node scripts/content-pipeline.mjs final-review",
    "content:run": "node scripts/content-pipeline.mjs run",
    "content:similarity": "node scripts/content-pipeline.mjs similarity",
    "content:advance": "node scripts/content-pipeline.mjs advance",
    "content:score": "node scripts/content-pipeline.mjs score",
    "content:gate": "node scripts/content-pipeline.mjs gate",
    "content:status": "node scripts/content-pipeline.mjs status",
    "content:manifest": "node scripts/content-pipeline.mjs apply-manifest"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^15.3.0",
    "next-mdx-remote": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reading-time": "^1.5.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.3",
    "@types/node": "^22.14.1",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
